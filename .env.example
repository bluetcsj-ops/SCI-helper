# Backend
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# LLM
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI fallback/optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Database
DATABASE_URL=sqlite:///./sci_workshop.db
# Production example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/sci_workshop

# Queue
REDIS_URL=redis://redis:6379/0

# Notification
TELEGRAM_BOT_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=sci-workshop

# Frontend
VITE_API_BASE_URL=http://localhost:8000
